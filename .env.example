# BureauBuddy Backend Configuration

# Model selection: 'gemini' or 'anthropic'
BB_MODEL=gemini

# Google Gemini API key (required if BB_MODEL=gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic API key (required if BB_MODEL=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CORS origin for local development
CORS_ORIGIN=chrome-extension://*
